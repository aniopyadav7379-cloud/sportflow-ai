# --- Database ---------------------------------------------------------------
# Postgres connection string (e.g. Neon, Supabase, RDS, or local Docker Postgres).
DATABASE_URL="postgresql://user:password@host:5432/sportflow?sslmode=require"

# --- Auth ---------------------------------------------------------------
# Generate a strong secret for production: `openssl rand -base64 32`
JWT_SECRET="dev-only-insecure-secret-change-me"

# --- Media storage (S3 / R2 / MinIO) ---------------------------------------
# Leave all blank to fall back to local disk storage under public/uploads
# (fine for local dev; not durable across redeploys — set these for prod).
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Only needed for S3-compatible providers (Cloudflare R2, Backblaze B2, MinIO).
# Leave blank for real AWS S3.
S3_ENDPOINT=""
# Optional custom public URL base (e.g. a CDN or R2 public bucket domain).
# If blank, falls back to the default AWS S3 virtual-hosted URL format.
S3_PUBLIC_URL_BASE=""

# --- AI Assistant (Groq) ---------------------------------------------------
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- App ---------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"